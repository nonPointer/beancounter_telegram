name = "beancounter-bot"
main = "src/index.ts"
compatibility_date = "2024-12-30"

[[kv_namespaces]]
binding = "KV"
id = "YOUR_KV_NAMESPACE_ID"  # wrangler kv namespace create KV

[vars]
REPO_OWNER = "your-github-username"
REPO_NAME = "your-beancount-repo"
BRANCH_NAME = "main"
FILE_PATH = "main.bean"
TIMEZONE = "Asia/Shanghai"
# CHAT_ID = "YOUR_TELEGRAM_CHAT_ID"  # optional: restrict to one chat

# Set secrets via CLI:
#   wrangler secret put TELEGRAM_BOT_TOKEN
#   wrangler secret put GITHUB_TOKEN
#   wrangler secret put WEBHOOK_SECRET
#   wrangler secret put LLM_API_KEY
#
# Set LLM configuration:
#   wrangler secret put LLM_API_BASE_URL --value "https://api.openai.com/v1"
#   wrangler secret put LLM_MODEL --value "gpt-4o-mini"
#
# Register webhook:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://<worker>.workers.dev&secret_token=<WEBHOOK_SECRET>"
