name: notify on push

on:
  push:
    branches: ["main"]

env:
  REPORT_CURRENCY: GBP
  FX_RATES: '{"CNY": 0.11, "USD": 0.79, "JPY": 0.005}'

jobs:
  notify-on-push:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 2

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Cache pip packages
        uses: actions/cache@v4
        with:
          path: ~/.cache/pip
          key: pip-beanquery-${{ runner.os }}

      - name: Install dependencies
        run: pip install --user beanquery

      - name: Notify monthly expenses
        env:
          TELEGRAM_TOKEN: ${{ secrets.TELEGRAM_TOKEN }}
          TELEGRAM_CHAT_ID: ${{ secrets.TELEGRAM_CHAT_ID }}
        run: |
          set -euo pipefail
          python3 << 'PYEOF'
          import subprocess, re, os, sys, json
          import urllib.request, urllib.parse, urllib.error
          from datetime import date

          report_ccy = os.environ['REPORT_CURRENCY']
          fx_rates = json.loads(os.environ.get('FX_RATES', '{}'))
          token = os.environ['TELEGRAM_TOKEN']
          chat_id = os.environ['TELEGRAM_CHAT_ID']

          today = date.today()
          first_day = today.replace(day=1)
          next_month = first_day.replace(
              year=first_day.year + (1 if first_day.month == 12 else 0),
              month=(first_day.month % 12) + 1,
          )
          month_label = first_day.strftime('%Y-%m')

          def run_query(q):
              r = subprocess.run(
                  ['bean-query', '-q', 'main.bean', q],
                  capture_output=True, text=True,
              )
              if r.returncode != 0:
                  print(f"bean-query failed:\n{r.stderr}", file=sys.stderr)
                  sys.exit(1)
              return r.stdout

          def to_report(amount, currency):
              if currency == report_ccy:
                  return amount
              rate = fx_rates.get(currency)
              return amount * rate if rate else amount

          output = run_query(
              f"SELECT account, cost(sum(position)) "
              f"WHERE account ~ '^Expenses:' "
              f"AND date >= {first_day} AND date < {next_month} "
              f"GROUP BY account ORDER BY account"
          )

          # Parse into {category: {currency: amount}}
          categories = {}
          current_account = None
          for line in output.strip().split('\n')[2:]:
              stripped = line.strip()
              if not stripped:
                  continue
              first_token = stripped.split()[0]
              if ':' in first_token:
                  current_account = first_token
                  amounts_str = stripped[len(first_token):]
              else:
                  amounts_str = stripped
              if current_account:
                  cat = current_account.split(':')[1]
                  if cat not in categories:
                      categories[cat] = {}
                  for amt, cur in re.findall(
                      r'(-?[\d,]+\.?\d*)\s+([A-Z]{3,})', amounts_str
                  ):
                      val = float(amt.replace(',', ''))
                      categories[cat][cur] = categories[cat].get(cur, 0) + val

          if not categories:
              print("No expense data.")
              sys.exit(0)

          # Build rows: (name, converted_total, display_amounts)
          rows = []
          grand_total = {}
          for cat, amounts in categories.items():
              converted = sum(to_report(v, c) for c, v in amounts.items())
              for c, v in amounts.items():
                  grand_total[c] = grand_total.get(c, 0) + v
              rows.append((cat, converted, amounts))

          rows.sort(key=lambda x: -x[1])

          # Format each row: "Category    1,234.56 GBP"
          # Show converted report-currency amount for clean single-column alignment
          lines = []
          max_name = max(len(r[0]) for r in rows)
          fmt_amounts = []
          for name, converted, _ in rows:
              s = f"{converted:,.0f}"
              fmt_amounts.append(s)
          max_amt = max(len(s) for s in fmt_amounts)

          for (name, converted, _), amt_s in zip(rows, fmt_amounts):
              lines.append(f"{name:<{max_name}}  {amt_s:>{max_amt}} {report_ccy}")

          # Total
          total_converted = sum(to_report(v, c) for c, v in grand_total.items())
          total_s = f"{total_converted:,.0f}"
          sep = '─' * (max_name + 2 + max_amt + 1 + len(report_ccy))
          lines.append(sep)
          lines.append(f"{'Total':<{max_name}}  {total_s:>{max_amt}} {report_ccy}")

          # Non-report currency footnote
          others = {c: v for c, v in grand_total.items() if c != report_ccy and abs(v) >= 0.5}
          if others:
              foot = ', '.join(f"{v:,.0f} {c}" for c, v in sorted(others.items()))
              lines.append(f"\n(incl. {foot})")

          msg = f"<b>Monthly Expenses — {month_label}</b>\n<pre>" + '\n'.join(lines) + "</pre>"

          data = urllib.parse.urlencode({
              'chat_id': chat_id, 'text': msg, 'parse_mode': 'HTML',
          }).encode()
          req = urllib.request.Request(
              f"https://api.telegram.org/bot{token}/sendMessage", data=data,
          )
          try:
              urllib.request.urlopen(req)
          except urllib.error.HTTPError as e:
              print(f"Telegram API returned {e.code}: {e.read().decode()}", file=sys.stderr)
              sys.exit(1)
          PYEOF

      - name: Notify account balances
        env:
          TELEGRAM_TOKEN: ${{ secrets.TELEGRAM_TOKEN }}
          TELEGRAM_CHAT_ID: ${{ secrets.TELEGRAM_CHAT_ID }}
        run: |
          set -euo pipefail
          python3 << 'PYEOF'
          import subprocess, re, os, sys
          import urllib.request, urllib.parse, urllib.error

          token = os.environ['TELEGRAM_TOKEN']
          chat_id = os.environ['TELEGRAM_CHAT_ID']

          # Read account names from commit body
          r = subprocess.run(
              ['git', 'log', '-1', '--pretty=%b'],
              capture_output=True, text=True,
          )
          accounts = [
              l.strip() for l in r.stdout.strip().split('\n')
              if l.strip() and re.match(r'^[A-Za-z0-9:]+$', l.strip())
          ]
          if not accounts:
              print("No account balances to report.")
              sys.exit(0)

          rows = []
          for account in accounts:
              r = subprocess.run(
                  ['bean-query', '-q', 'main.bean',
                   f"SELECT sum(position) WHERE account = '{account}'"],
                  capture_output=True, text=True,
              )
              amounts = []
              for line in r.stdout.strip().split('\n')[2:]:
                  stripped = line.strip()
                  if not stripped:
                      continue
                  for amt, cur in re.findall(
                      r'(-?[\d,]+\.?\d*)\s+([A-Z]{3,})', stripped
                  ):
                      val = float(amt.replace(',', ''))
                      amounts.append(f"{val:,.2f} {cur}")

              short = ':'.join(account.split(':')[-2:])
              balance = ', '.join(amounts) if amounts else '(empty)'
              rows.append((short, balance))

          if not rows:
              sys.exit(0)

          max_name = max(len(r[0]) for r in rows)
          lines = [f"{name:<{max_name}}  {bal}" for name, bal in rows]
          msg = "<b>Account Balances</b>\n<pre>" + '\n'.join(lines) + "</pre>"

          data = urllib.parse.urlencode({
              'chat_id': chat_id, 'text': msg, 'parse_mode': 'HTML',
          }).encode()
          req = urllib.request.Request(
              f"https://api.telegram.org/bot{token}/sendMessage", data=data,
          )
          try:
              urllib.request.urlopen(req)
          except urllib.error.HTTPError as e:
              print(f"Telegram API returned {e.code}: {e.read().decode()}", file=sys.stderr)
              sys.exit(1)
          PYEOF
